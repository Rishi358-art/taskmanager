@model TaskManager.Web.ViewModels.TaskDetailsViewModel

@{
    ViewData["Title"] = "Task Details";
}

<div class="row justify-content-center">

<div class="col-md-8">

<!-- TASK CARD -->

<div class="card shadow-lg border-0 mb-4">

<div class="card-body p-4">

<h3 class="fw-bold">@Model.Title</h3>

<p class="text-muted mt-3">
@Model.Description
</p>

<div class="mt-4">

<a asp-action="Complete"
   asp-route-id="@Model.Id"
   class="btn btn-success">
   Complete Task
</a>

<a asp-action="Delete"
   asp-route-id="@Model.Id"
   class="btn btn-danger">
   Delete Task
</a>

<a asp-action="Index"
   class="btn btn-secondary">
   Back
</a>

</div>

</div>
</div>

<!-- COMMENTS -->

<div class="card shadow-sm border-0">

<div class="card-body p-4">

<h5 class="mb-3 fw-bold">Comments</h5>

@if (!Model.Comments.Any())
{
<p class="text-muted">No comments yet.</p>
}

@foreach (var comment in Model.Comments)
{
<div class="border rounded p-3 mb-3">

<strong>@comment.UserName</strong>

<p class="mb-1">
@comment.Comment
</p>

<small class="text-muted">
@comment.CreatedAt.ToString("dd MMM yyyy HH:mm")
</small>
<form asp-controller="TaskComments"
      asp-action="Delete"
      method="post"
      class="mt-2">

    <input type="hidden" name="commentId" value="@comment.Id" />
   <input type="hidden" name="taskId" value="@Model.Id" />

    <button class="btn btn-sm btn-outline-danger mt-2">Delete</button>

</form>
</div>
}

</div>

</div>

</div>

</div>