@model TaskManager.Web.ViewModels.TaskCreateViewModel

@{
    ViewData["Title"] = "Create Task";
}

<div class="row justify-content-center">

    <div class="col-md-6">

        <div class="card shadow-lg border-0">

            <div class="card-body p-4">

                <h3 class="text-center mb-4 fw-bold">Create New Task</h3>

                <form asp-action="Create" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- Title -->
                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold"></label>

                        <input asp-for="Title"
                               class="form-control"
                               placeholder="Enter task title" />

                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Enter task description"></textarea>

                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <!-- Due Date -->
                    <div class="mb-3">
                        <label asp-for="DueDate" class="form-label fw-semibold"></label>

                        <input asp-for="DueDate"
                               type="date"
                               class="form-control" />
                    </div>

                    <!-- Priority -->
                    <div class="mb-3">
                        <label asp-for="Priority" class="form-label fw-semibold"></label>

                        <select asp-for="Priority"
                                class="form-select"
                                asp-items="Html.GetEnumSelectList<TaskManager.Domain.Enums.Priority>()">
                        </select>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2 mt-4">

                        <button type="submit" class="btn btn-success w-50">
                            Create Task
                        </button>

                        <a asp-action="Index" class="btn btn-secondary w-50">
                            Cancel
                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}