@model List<TaskManager.Web.ViewModels.TaskViewModel>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Your Tasks</h2>
        <a href="/Tasks/Create" class="btn btn-primary">+ Create Task</a>
    </div>

    <!-- Search -->
    <form method="get" action="/Tasks/Index" class="mb-3">
        <div class="input-group">
            <input type="text" class="form-control" name="search" value="@ViewBag.Search" placeholder="Search tasks..." />
            <button class="btn btn-outline-primary" type="submit">Search</button>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th style="width:250px;">Actions</th>
                        <th>Comments</th>
                    </tr>
                </thead>

                <tbody>
                @foreach(var task in Model)
                {
                    <tr>
                        <td>
                            <strong>@task.Title</strong>
                        </td>

                        <td>
                            @if(task.Status.ToString() == "Completed")
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pending</span>
                            }
                        </td>

                        <td>
                            @if(task.Priority.ToString() == "High")
                            {
                                <span class="badge bg-danger">High</span>
                            }
                            else if(task.Priority.ToString() == "Medium")
                            {
                                <span class="badge bg-info text-dark">Medium</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Low</span>
                            }
                        </td>

                        <td>
                            <a href="/Tasks/Details/@task.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                            <a href="/Tasks/Complete/@task.Id" class="btn btn-sm btn-outline-success">Complete</a>
                            <a href="/Tasks/Delete/@task.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>

                        <td>
                            <form method="post" action="/TaskComments/Add">
                                <input type="hidden" name="taskId" value="@task.Id" />
                                <textarea class="form-control mb-2" name="comment" placeholder="Add comment..." required></textarea>
                                <button class="btn btn-sm btn-primary">Add</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>

            </table>
          </div>
        </div>
    </div>


   <!-- Pagination -->
<div class="mt-3 d-flex justify-content-center">

    <nav>
        <ul class="pagination">

            <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link" href="/Tasks/Index?page=@(ViewBag.CurrentPage - 1)&search=@ViewBag.Search">
                    Previous
                </a>
            </li>

            @for (int i = 1; i <= (ViewBag.PageCount ?? 1); i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" href="/Tasks/Index?page=@i&search=@ViewBag.Search">@i</a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage >= ViewBag.PageCount ? "disabled" : "")">
                <a class="page-link" href="/Tasks/Index?page=@(ViewBag.CurrentPage + 1)&search=@ViewBag.Search">
                    Next
                </a>
            </li>

        </ul>
    </nav>

</div>

</div>