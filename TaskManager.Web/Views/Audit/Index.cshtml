@model List<TaskManager.Domain.Entities.AuditLog>

<div class="container mt-4">

    <h2 class="mb-3">System Audit Logs</h2>

    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Entity Id</th>
                        <th>Time</th>
                    </tr>
                </thead>

                <tbody>

                @foreach (var log in Model)
                {
                    <tr>

                        <td>
                            <span class="badge bg-primary">
                                @log.Action
                            </span>
                        </td>

                        <td>
                            @log.EntityName
                        </td>

                        <td>
                            <small class="text-muted">
                                @log.EntityId
                            </small>
                        </td>

                        <td>
                            @log.Timestamp.ToString("yyyy-MM-dd HH:mm")
                        </td>

                    </tr>
                }

                </tbody>

            </table>

        </div>
    </div>

</div>